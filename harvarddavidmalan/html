<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>uzoom — eye</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<style>
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:#000;width:100vw;height:100vh;overflow:hidden;font-family:'Share Tech Mono',monospace;}
  canvas{display:block;}
  .scanline{position:fixed;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(to bottom,transparent 0px,transparent 3px,rgba(0,0,0,0.06) 3px,rgba(0,0,0,0.06) 4px);pointer-events:none;z-index:10;}
  .vignette{position:fixed;top:0;left:0;width:100%;height:100%;background:radial-gradient(ellipse at center,transparent 30%,rgba(0,0,0,0.92) 100%);pointer-events:none;z-index:9;}
  #skipBtn{position:fixed;bottom:12vh;right:30px;z-index:25;font-family:'Share Tech Mono',monospace;font-size:11px;color:rgba(160,160,160,0.5);border:1px solid rgba(160,160,160,0.25);padding:5px 14px;background:rgba(0,0,0,0.6);pointer-events:none;opacity:0;letter-spacing:2px;}
</style>
</head>
<body>
<canvas id="c"></canvas>
<div class="scanline"></div>
<div class="vignette"></div>
<div id="skipBtn">PULAR ABERTURA ▶</div>

<script>
const canvas=document.getElementById('c'),ctx=canvas.getContext('2d');
// Force 9:16 (1080x1920)
let W=1080,H=1920;
canvas.width=W;canvas.height=H;
canvas.style.width='100vw';canvas.style.height='100vh';canvas.style.objectFit='contain';
window.addEventListener('resize',()=>{cacheGeo();});
const CX=()=>W/2,CY=()=>H/2;

// === BIGGER FONT ===
const FONT_SIZE=14;
const FONT=`${FONT_SIZE}px 'Share Tech Mono',Courier New,monospace`;
const LINE_H=26;

const allText=[
  '[SYSTEM] — initializing.core_kernel() ... OK',
  '[ROCKY] — 42.2km // 276m.elev() // limite.redefinido()',
  '[TURING] — throws NullPointerException // corrigido às 2am',
  '[DOSTOEVSKI] — pg.087 // Crime e Castigo // Raskolnikov.loop()',
  '[AZNAVOUR] — vocab++ // sotaque ainda undefined // dia_01',
  '[FACULDADE] — present: true // às vezes // prova.na.sexta',
  '[GOGGINS] — meta=65kg // deficit = disciplina // foco',
  '[H2O] — hydration.status != opcional // beba mais',
  '[TURING] — implements Disciplina extends Rotina // commit ok',
  '[ROCKY] — 21.1km // 140m.elev() // metade.do.caminho()',
  '[DOSTOEVSKI] — pg.231 // Duna // o.deserto.não.espera',
  '[AZNAVOUR] — fluência.status = em_progresso // dia_14',
  '[GOGGINS] — void comer(int kcal) { if(lazy) override(); }',
  '[NETWORK] — scanning.nodes() ... 127.0.0.1 found',
  '[SECURITY] — firewall.breach_detected() // counter_measures.init()',
];
const inspireText='BOB MARLEY  ·  CHARLIE BROWN JUNIOR  ·  WALTER WHITE  ·  CHANDLER  ·  JOEY  ·  BETTER CALL SAUL  ·  O URSO  ·  CLAIRE  ·  BERZATO  ·  OH MY CAPTAIN  ·  RUN FORREST  ·  NOLAN  ·  INTERSTELLAR  ·  FARGO  ·  1984  ·  NOITES BRANCAS  ·  MORTE DO AUTOTUNE  ·  CRÔNICAS DE GELO  ·  O ENIGMA DO PRÍNCIPE  ·  PULP FICTION  ·  BENTO SANTIAGO  ·  LISAN AL GAIB  ·  COBB  ·  MARTY SUPREME  ·  TARS  ·  GUS FRING  ·  POLLOS HERMANOS  ·  TRAVIS BICKLE  ·  RUST COHLE  ·  YE  ·  ';

ctx.font=FONT;const charW=ctx.measureText('M').width;
function ease(t){return t<0.5?4*t*t*t:1-Math.pow(-2*t+2,3)/2;}

// SCROLL LINES
const numLines=Math.ceil(H/LINE_H)+4;const scrollLines=[];
for(let i=0;i<numLines;i++){const isI=i%5===3,dir=i%2===0?1:-1;
  const bt=isI?inspireText:allText[i%allText.length];let ft='';while(ft.length<400)ft+=bt+'   ';
  const dep=Math.random();
  scrollLines.push({y:i*LINE_H,offset:Math.random()*800,speed:(0.25+Math.random()*0.3)*dir*(0.8+dep*0.4),isInspire:isI,text:ft,textLen:ft.length,opacity:0.25+dep*0.75});}

// === EYE GEOMETRY — bigger, more detailed ===
let _ew,_eh,_ir,_pr;
function cacheGeo(){_ew=Math.min(W,H)*0.44;_eh=_ew*0.4;_ir=_eh*0.8;_pr=_ir*0.36;}
cacheGeo();
function isInAlm(x,y,m){const nx=x/(_ew+(m||0)),ny=y/(_eh+(m||0));return Math.abs(nx)<=1&&Math.abs(ny)<=Math.pow(Math.max(0,1-nx*nx),0.7);}
function almSDF(x,y){const nx=x/_ew,ny=y/_eh;if(Math.abs(nx)>1.05)return-1;return Math.pow(Math.max(0,1-nx*nx),0.7)-Math.abs(ny);}

function classify(rx,ry){
  const pD=Math.sqrt(rx*rx+ry*ry);
  // Highlight — bigger
  if(Math.sqrt((rx+_pr*0.35)**2+(ry+_pr*0.35)**2)<_pr*0.28)return{z:'hl',d:1};
  // Pupil — very sparse center for dark void
  if(pD<_pr*0.6)return{z:'pup',d:0.06};
  if(pD<_pr)return{z:'pup',d:0.1+(pD/_pr)*0.05};
  // Pupil ring — dense bright border
  if(pD<_pr*1.18)return{z:'pr',d:0.95};
  // Iris — with fiber pattern, denser at limbal ring
  if(pD<_ir){const t=pD/_ir;
    const limb=t>0.82?0.98:0.5+t*0.35;
    const fiber=Math.abs(Math.sin(Math.atan2(ry,rx)*20))*0.12;
    return{z:'iris',d:limb+fiber};}
  // Iris outer ring
  if(pD<_ir*1.1)return{z:'ir',d:0.98};
  // Outside almond
  if(!isInAlm(rx,ry)){
    if(isInAlm(rx,ry,8))return{z:'out',d:0.9};
    // Lashes
    const nx=rx/_ew;if(Math.abs(nx)<0.92){
      const maxY=Math.pow(Math.max(0,1-nx*nx),0.7)*_eh;
      if(ry<0&&ry>-maxY-_eh*0.3)return{z:'lash',d:0.25+Math.random()*0.15};
    }
    return{z:'x',d:0};}
  // Veins
  if(Math.random()<0.035)return{z:'vein',d:0.55};
  // Sclera
  return{z:'scl',d:0.12+Math.min(0.22,almSDF(rx,ry)*0.7)};
}

// === DENSER GRID for sharper eye ===
function buildTgt(){const t=[];
  for(let gy=-_eh*1.35;gy<_eh*1.35;gy+=5)
    for(let gx=-_ew*1.1;gx<_ew*1.1;gx+=5){
      const info=classify(gx,gy);if(info.z==='x'||Math.random()>info.d)continue;
      t.push({x:CX()+gx,y:CY()+gy,z:info.z});}
  return t;}

// PARTICLES
const particles=[];const CPL=Math.ceil(W/charW)+8;
for(let row=0;row<numLines;row++){const line=scrollLines[row];
  for(let col=0;col<CPL;col++){const ci=col%line.textLen;const ch=line.text[ci];if(ch===' ')continue;
    const c12=line.text.substring(Math.max(0,ci-12),ci+1);
    particles.push({char:ch,row,col,lineRef:line,scrollY:line.y,isInspire:line.isInspire,
      isBracket:(ch==='['||ch===']'||c12.lastIndexOf('[')>c12.lastIndexOf(']')),
      eyeX:0,eyeY:0,ez:'none',has:false,delay:0,opacity:line.opacity});}}

function assignTgt(targets){particles.forEach(p=>{p.has=false;p.ez='none';});
  const idx=particles.map((_,i)=>i).sort(()=>Math.random()-0.5);
  for(let i=0;i<Math.min(idx.length,targets.length);i++){const pt=particles[idx[i]],tg=targets[i];
    pt.eyeX=tg.x;pt.eyeY=tg.y;pt.ez=tg.z;pt.has=true;
    const d=Math.sqrt(((tg.x-CX())/_ew)**2+((tg.y-CY())/_eh)**2);
    pt.delay=tg.z==='hl'?0.55:tg.z==='pup'||tg.z==='pr'?0.42+d*0.1:tg.z==='iris'||tg.z==='ir'?0.25+d*0.1:tg.z==='out'?d*0.12:d*0.18;}}
assignTgt(buildTgt());

// === MORE VIBRANT COLORS ===
function getCol(pt,m){
  const fl=Math.random()<0.03?0.4:1;
  if(m<0.01||!pt.has){
    const a=pt.opacity*(1-m)*fl;
    if(pt.isInspire)return`rgba(55,200,55,${a})`;         // brighter green
    if(pt.isBracket)return`rgba(235,50,50,${a*1.15})`;    // brighter red
    return`rgba(185,185,185,${a})`;                         // brighter gray
  }
  let er,eg,eb,ea;const z=pt.ez;
  if(z==='hl'){er=255;eg=245;eb=245;ea=0.98;}             // bright white highlight
  else if(z==='pup'){er=8;eg=2;eb=2;ea=0.95;}             // deeper black pupil
  else if(z==='pr'){er=220;eg=40;eb=38;ea=0.95;}          // vivid red pupil ring
  else if(z==='ir'){er=230;eg=55;eb=50;ea=0.92;}          // vivid iris ring
  else if(z==='iris'){
    if(pt.isInspire){er=60;eg=220;eb=60;ea=0.9;}          // vivid green in iris
    else{er=210;eg=50;eb=42;ea=0.85;}                      // vivid red iris
  }
  else if(z==='out'){er=235;eg=60;eb=55;ea=0.9;}          // bright outline
  else if(z==='lash'){er=180;eg=45;eb=42;ea=0.7;}
  else if(z==='vein'){er=190;eg=55;eb=50;ea=0.6;}
  else{                                                     // sclera
    if(pt.isInspire){er=55;eg=185;eb=55;ea=0.6;}
    else if(pt.isBracket){er=220;eg=65;eb=60;ea=0.65;}
    else{er=200;eg=200;eb=200;ea=0.5;}
  }
  let sr=pt.isInspire?55:pt.isBracket?235:185;
  let sg=pt.isInspire?200:pt.isBracket?50:185;
  let sb=pt.isInspire?55:pt.isBracket?50:185;
  let sa=pt.opacity;
  return`rgba(${(sr+(er-sr)*m)|0},${(sg+(eg-sg)*m)|0},${(sb+(eb-sb)*m)|0},${(sa+(ea-sa)*m)*fl})`;
}

// =========================================================
//  STATE & GSAP TIMELINE
// =========================================================
const S={
  hboPhase:1,sAlpha:0,sSpeed:0.3,tSpeed:0.3,
  focusLine:-1,focusAmt:0,alertTxt:'',alertAlpha:0,
  termProg:0,scanPos:0,beamPos:0,cursorVis:true,
  morph:0,lookX:0,
  finalG:0,skipAlpha:0,
  chromatic:0,shake:0,grain:0.45,
};

const tl=gsap.timeline();

// === HBO STATIC (0-2.5s) ===
tl.to(S,{hboPhase:0.5,duration:1.2,ease:'power1.in'},0)
  .to(S,{hboPhase:0,duration:1.2,ease:'power2.in'},1.8)

// === TEXT SCROLL (2.5-17s) — longer for readability ===
  .to(S,{sAlpha:1,duration:0.8},2.5)
  .to(S,{termProg:1,duration:3.5,ease:'none'},2.8)
  .to(S,{scanPos:1,duration:3,ease:'none',repeat:-1},2.5)
  .to(S,{beamPos:1,duration:8,ease:'power1.inOut',repeat:-1,yoyo:true},2.5)

  // Focus 1: System Init (4-7.5s)
  .set(S,{focusLine:0,alertTxt:'SYSTEM_INITIALIZED',alertAlpha:1},4)
  .to(S,{focusAmt:1,chromatic:5,shake:1.5,duration:0.12},4)
  .to(S,{tSpeed:0.006,duration:2.8,ease:'power2.out'},4.1)
  .to(S,{focusAmt:0,alertAlpha:0,chromatic:0,shake:0,duration:0.6},7.2)
  .to(S,{tSpeed:0.35,duration:1,ease:'power2.in'},7.2)

  // Readable scroll (8-12s) — nice and slow
  .to(S,{tSpeed:0.28,duration:2.5,ease:'power1.inOut'},8.5)

  // Focus 2: Breach (12-15.5s)
  .set(S,{focusLine:14,alertTxt:'BREACH_DETECTED',alertAlpha:1},12)
  .to(S,{focusAmt:1,chromatic:6,shake:2,duration:0.12},12)
  .to(S,{tSpeed:0.004,duration:3.5,ease:'power3.out'},12.1)
  .to(S,{focusAmt:0,alertAlpha:0,chromatic:0,shake:0,duration:0.6},15.5)

// === SKIP BUTTON (5s → end) ===
  .to(S,{skipAlpha:1,duration:0.4},5)

// === ACCELERATE + MORPH INTO EYE (16-24s) — more time ===
  .to(S,{tSpeed:6,duration:1.2,ease:'power3.in'},16)
  .to(S,{tSpeed:0.008,duration:2.5,ease:'power3.out'},17.2)
  .to(S,{morph:1,duration:7,ease:'power2.inOut'},17)
  .to(S,{tSpeed:0,duration:2},17)
  .to(S,{shake:2.5,duration:0.12,yoyo:true,repeat:1},17)
  .to(S,{chromatic:8,duration:0.15,yoyo:true,repeat:1},17)

// === EYE HOLDS — pupil looks (24-30s) — more time to appreciate ===
;[{x:0.8,t:24.5},{x:0,t:25.8},{x:-0.85,t:27},{x:0,t:28.3},{x:0.4,t:29.2},{x:-0.5,t:29.8},{x:0,t:30.5}]
  .forEach(l=>tl.to(S,{lookX:l.x,duration:1,ease:'power4.inOut'},l.t));

// === FINAL GLITCH → BLACK (31-33.5s) ===
tl.to(S,{skipAlpha:0,duration:0.3},31)
  .to(S,{finalG:1,duration:2.5,ease:'power2.in'},31);

gsap.to(S,{cursorVis:false,duration:0.4,repeat:-1,yoyo:true,ease:'steps(1)'});

// =========================================================
//  EFFECTS
// =========================================================
function chromAb(s){if(s<1)return;const sh=s|0,img=ctx.getImageData(0,0,W,H),d=img.data,c=new Uint8ClampedArray(d);
  for(let y=0;y<H;y+=2)for(let x=0;x<W;x++){const i=(y*W+x)*4;d[i]=c[(y*W+Math.min(W-1,Math.max(0,x+sh)))*4];d[i+2]=c[(y*W+Math.min(W-1,Math.max(0,x-sh)))*4+2];
    if(y+1<H){const i2=((y+1)*W+x)*4;d[i2]=c[((y+1)*W+Math.min(W-1,Math.max(0,x+sh)))*4];d[i2+2]=c[((y+1)*W+Math.min(W-1,Math.max(0,x-sh)))*4+2];}}
  ctx.putImageData(img,0,0);}

function grainFx(a){const img=ctx.getImageData(0,0,W,H),d=img.data,str=22+a*50;
  for(let i=0;i<d.length;i+=6){const n=((Math.random()-0.5)*str)|0;d[i]+=n*1.2;d[i+1]+=n*0.65;d[i+2]+=n*0.65;}
  ctx.putImageData(img,0,0);}

function glitchR(){if(Math.random()>0.92){const sy=Math.random()*H|0,sh=1+Math.random()*28|0;
  try{ctx.putImageData(ctx.getImageData(0,sy,W,sh),((Math.random()-0.5)*55)|0,sy);}catch(e){}}
  if(Math.random()>0.97)chromAb(3+Math.random()*7);}

function finalFx(t){
  if(t<0.85){const s=(8+t*120)|0,img=ctx.getImageData(0,0,W,H),d=img.data,c=new Uint8ClampedArray(d);
    for(let y=0;y<H;y+=2){const rs=((Math.random()-0.5)*s)|0;for(let x=0;x<W;x++){const i=(y*W+x)*4;
      d[i]=c[(y*W+Math.min(W-1,Math.max(0,x+s+rs)))*4];d[i+2]=c[(y*W+Math.min(W-1,Math.max(0,x-s-rs)))*4+2];}}ctx.putImageData(img,0,0);}
  for(let s=0;s<Math.min(40,(5+t*42)|0);s++){const sy=Math.random()*H|0,sh=(2+Math.random()*(8+t*75))|0;
    if(sh>0&&sy+sh<H)try{ctx.putImageData(ctx.getImageData(0,sy,W,sh),((Math.random()-0.5)*(55+t*320))|0,sy);}catch(e){}}
  if(t>0.2)for(let b=0;b<((t-0.2)*16|0);b++){ctx.fillStyle=`rgba(0,0,0,${0.4+t*0.6})`;ctx.fillRect(Math.random()*W|0,Math.random()*H|0,(15+Math.random()*t*210)|0,(2+Math.random()*t*32)|0);}
  if(Math.random()<t*0.5){ctx.fillStyle=Math.random()>0.5?'rgba(235,50,50,0.1)':'rgba(255,255,255,0.06)';ctx.fillRect(0,0,W,H);}
  if(t>0.55){ctx.fillStyle=`rgba(0,0,0,${(t-0.55)*2.2})`;ctx.fillRect(0,0,W,H);}
}

function drawStatic(ph){if(ph<=0)return;const img=ctx.createImageData(W,H),d=img.data;
  for(let i=0;i<d.length;i+=4){const v=Math.random()*95*ph;d[i]=Math.min(255,v*1.35+Math.random()*28*ph);d[i+1]=v*0.28|0;d[i+2]=v*0.28|0;d[i+3]=255*ph;}
  for(let y=0;y<H;y++){if(Math.random()<0.028*ph){const br=75+Math.random()*110;for(let x=0;x<W;x++){const i=(y*W+x)*4;d[i]=br*0.85;d[i+1]=br*0.18;d[i+2]=br*0.18;d[i+3]=210*ph;}}}
  ctx.putImageData(img,0,0);}

// =========================================================
//  RENDER
// =========================================================
function render(){
  S.sSpeed+=(S.tSpeed-S.sSpeed)*0.1;
  let ox=0,oy=0;if(S.shake>0){ox=(Math.random()-0.5)*S.shake;oy=(Math.random()-0.5)*S.shake;}
  ctx.save();ctx.translate(ox,oy);ctx.fillStyle='#000';ctx.fillRect(-ox,-oy,W,H);

  // HBO STATIC
  if(S.hboPhase>0.01){drawStatic(S.hboPhase);ctx.restore();grainFx(S.grain*1.5);requestAnimationFrame(render);return;}

  // SCROLL + MORPH
  if(S.sAlpha>0.01){
    for(let i=0;i<scrollLines.length;i++)scrollLines[i].offset+=scrollLines[i].speed*S.sSpeed;
    ctx.font=FONT;

    for(let i=0;i<particles.length;i++){
      const pt=particles[i],line=pt.lineRef;
      if(S.morph<0.1&&pt.row/numLines>S.termProg)continue;
      const tpw=line.textLen*charW;let sx=pt.col*charW-line.offset;sx=((sx%tpw)+tpw)%tpw;

      if(!pt.has){const a=Math.max(0,1-S.morph*1.4);if(a<0.02)continue;
        let la=a*S.sAlpha*pt.opacity;
        const scanY=S.scanPos*H;if(Math.abs(pt.scrollY-scanY)<100)la*=(1+(1-Math.abs(pt.scrollY-scanY)/100)*1.8);
        if(S.focusLine!==-1){if(pt.row===S.focusLine){la*=(1+S.focusAmt*5);
          if(pt.col===0){ctx.save();ctx.globalAlpha=S.focusAmt*0.18;ctx.fillStyle='#e03030';ctx.fillRect(sx-20,pt.scrollY-17,tpw+40,28);ctx.restore();}}
          else la*=(1-S.focusAmt*0.97);}
        ctx.globalAlpha=la;ctx.fillStyle=getCol(pt,0);
        let ch=pt.char;if(S.morph<0.05&&Math.random()<0.25)ch=String.fromCharCode(33+(Math.random()*94|0));
        ctx.fillText(ch,sx,pt.scrollY);continue;}

      let m=Math.max(0,Math.min(1,(S.morph-pt.delay)/Math.max(0.01,1-pt.delay)));m=ease(m);
      const z=pt.ez;let psx=0;
      if(z==='pup'||z==='pr'||z==='hl')psx=S.lookX*_ew*0.12;
      else if(z==='iris'||z==='ir')psx=S.lookX*_ew*0.06;
      const tx=pt.eyeX+psx,ty=pt.eyeY;
      let dx,dy;if(m>=0.995){dx=tx;dy=ty;}else{dx=sx+(tx-sx)*m;dy=pt.scrollY+(ty-pt.scrollY)*m;}
      if(S.finalG>0){const fp=S.finalG;dx+=(Math.random()-0.5)*fp*210;dy+=(Math.random()-0.5)*fp*130;if(Math.random()<fp*0.95)continue;}
      if(dx<-20||dx>W+20||dy<-10||dy>H+10)continue;
      ctx.globalAlpha=S.sAlpha;ctx.fillStyle=getCol(pt,m);ctx.fillText(pt.char,dx,dy);
    }

    // Pupil glow — more visible
    if(S.morph>0.5&&S.finalG<0.3){const ga=(S.morph-0.5)*2*0.14;
      const gx=CX()+S.lookX*_ew*0.12,gy=CY();
      const grd=ctx.createRadialGradient(gx,gy,0,gx,gy,_pr*2.5);
      grd.addColorStop(0,`rgba(235,50,50,${ga})`);grd.addColorStop(1,'transparent');
      ctx.fillStyle=grd;ctx.beginPath();ctx.arc(gx,gy,_pr*2.5,0,Math.PI*2);ctx.fill();}
  }

  // Terminal UI — bigger alert font
  if(S.morph<0.9&&S.sAlpha>0.1){
    ctx.globalAlpha=(1-S.morph)*S.sAlpha*0.75;ctx.fillStyle='rgba(200,200,200,0.4)';
    ctx.font="11px 'Share Tech Mono',monospace";
    ctx.fillText(`UZX_CORE // STATUS: ${S.morph>0.5?'MORPHING':'SCANNING'}${S.cursorVis?'_':' '}`,40,40);
    if(S.alertAlpha>0){ctx.globalAlpha=S.alertAlpha;ctx.fillStyle='rgba(235,50,50,1)';
      ctx.font="bold 20px 'Share Tech Mono',monospace";
      ctx.fillText(`> ${S.alertTxt}`,CX()-150,CY()+H*0.3);}
    ctx.globalAlpha=1;}

  // Light beam — slightly more visible
  if(S.morph<0.9&&S.sAlpha>0.3){const bx=S.beamPos*W;
    const grd=ctx.createLinearGradient(bx-150,0,bx+150,0);
    grd.addColorStop(0,'transparent');grd.addColorStop(0.5,'rgba(235,50,50,0.07)');grd.addColorStop(1,'transparent');
    ctx.fillStyle=grd;ctx.globalCompositeOperation='screen';ctx.fillRect(bx-150,0,300,H);ctx.globalCompositeOperation='source-over';}

  ctx.restore();

  // Post-processing
  if(S.chromatic>0)chromAb(S.chromatic);
